{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindflow.local/schema/productFlow.schema.json",
  "title": "ProductFlow",
  "type": "object",
  "required": [
    "schemaVersion",
    "flowId",
    "revision",
    "title",
    "sourceDocumentId",
    "sourceSummary",
    "createdAt",
    "updatedAt",
    "projectOverview",
    "domains",
    "roles",
    "nodes",
    "edges",
    "artifacts",
    "changeHistory",
    "syncState"
  ],
  "properties": {
    "schemaVersion": { "type": "string" },
    "flowId": { "type": "string" },
    "revision": { "type": "number" },
    "title": { "type": "string" },
    "sourceDocumentId": { "type": "string" },
    "sourceSummary": { "type": "string" },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "projectOverview": {
      "type": "object",
      "required": ["summary", "goal"],
      "properties": {
        "summary": { "type": "string" },
        "goal": { "type": "string" },
        "view": {
          "type": "object",
          "properties": {
            "position": {
              "type": "object",
              "required": ["x", "y"],
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" }
              }
            }
          }
        }
      }
    },
    "domains": { "type": "array" },
    "roles": { "type": "array" },
    "appSurfaces": { "type": "array" },
    "statusGroups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["statusGroupId", "title", "color"],
        "properties": {
          "statusGroupId": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "color": {
            "type": "string",
            "pattern": "^#[0-9a-fA-F]{6}$"
          }
        }
      }
    },
    "nodes": { "type": "array" },
    "edges": { "type": "array" },
    "artifacts": {
      "type": "object",
      "required": ["prds", "pencils"],
      "properties": {
        "prds": { "type": "array" },
        "pencils": { "type": "array" }
      }
    },
    "changeHistory": { "type": "array" },
    "syncState": {
      "type": "object",
      "required": ["issues"],
      "properties": {
        "lastSyncedAt": { "type": "string" },
        "issues": { "type": "array" }
      }
    },
    "productDesignIssues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["issueId", "severity", "title", "description", "prompt"],
        "properties": {
          "issueId": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["critical", "warning", "optional"]
          },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "prompt": { "type": "string" },
          "relatedNodeIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "relatedEdgeIds": {
            "type": "array",
            "items": { "type": "string" }
          },
          "sourceRefs": { "type": "array" }
        }
      }
    },
    "openQuestions": { "type": "array" }
  }
}
