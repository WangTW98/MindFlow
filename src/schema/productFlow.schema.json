{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindflow.local/schema/productFlow.schema.json",
  "title": "ProductFlow",
  "type": "object",
  "required": [
    "schemaVersion",
    "flowId",
    "revision",
    "title",
    "createdAt",
    "updatedAt",
    "projectOverview",
    "domains",
    "roles",
    "nodes",
    "edges"
  ],
  "properties": {
    "schemaVersion": { "type": "string", "const": "2.0" },
    "flowId": { "type": "string" },
    "revision": { "type": "number" },
    "title": { "type": "string" },
    "createdAt": { "type": "string" },
    "updatedAt": { "type": "string" },
    "projectOverview": {
      "type": "object",
      "required": ["summary", "goal"],
      "properties": {
        "summary": { "type": "string" },
        "goal": { "type": "string" },
        "view": {
          "type": "object",
          "properties": {
            "position": {
              "type": "object",
              "required": ["x", "y"],
              "properties": {
                "x": { "type": "number" },
                "y": { "type": "number" }
              }
            }
          }
        }
      }
    },
    "domains": { "type": "array" },
    "roles": { "type": "array" },
    "appSurfaces": { "type": "array" },
    "statusGroups": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["statusGroupId", "title", "color"],
        "properties": {
          "statusGroupId": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "color": {
            "type": "string",
            "pattern": "^#[0-9a-fA-F]{6}$"
          }
        }
      }
    },
    "nodes": { "type": "array" },
    "edges": { "type": "array" }
  }
}
