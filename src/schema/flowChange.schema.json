{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mindflow.local/schema/flowChange.schema.json",
  "title": "FlowChangePlan",
  "type": "object",
  "required": [
    "changeSetId",
    "flowId",
    "baseRevision",
    "instruction",
    "intent",
    "requiresClarification",
    "operations",
    "affectedNodeIds",
    "affectedEdgeIds",
    "artifactImpact",
    "openQuestions",
    "confidence"
  ],
  "properties": {
    "changeSetId": { "type": "string" },
    "flowId": { "type": "string" },
    "baseRevision": { "type": "number" },
    "instruction": { "type": "string" },
    "intent": { "type": "string" },
    "requiresClarification": { "type": "boolean" },
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "opId",
          "type",
          "target",
          "before",
          "after",
          "reason",
          "risk",
          "requiresConfirmation"
        ]
      }
    },
    "affectedNodeIds": { "type": "array" },
    "affectedEdgeIds": { "type": "array" },
    "artifactImpact": { "type": "array" },
    "openQuestions": { "type": "array" },
    "confidence": { "type": "number" }
  }
}
