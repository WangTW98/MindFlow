out/
out-test/
dist/
build/
*.tsbuildinfo
*.vsix
*.tgz

# Test and coverage outputs
coverage/
.nyc_output/
test-results/
playwright-report/
junit*.xml
*.lcov
.vscode-test/
.vscode-test-web/

# Tool caches, temporary files, and logs
.cache/
.parcel-cache/
.eslintcache
.tmp/
tmp/
*.tmp
*.temp
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
