{
  "compilerOptions": {
    "target": "ES2020",
    "module": "none",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "useUnknownInCatchVariables": false,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": [
    "src/platform/webview/canvas/client/**/*.ts",
    "src/platform/webview/canvas/client/**/*.d.ts"
  ]
}
