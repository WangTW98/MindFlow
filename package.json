{
  "name": "mindflow-canvas-editor",
  "displayName": "MindFlow Canvas Editor",
  "description": "Edit .mindflow ProductFlow node canvases locally in VS Code.",
  "version": "0.1.0",
  "publisher": "mindflow",
  "repository": {
    "type": "git",
    "url": "https://github.com/WangTW98/MindFlow.git"
  },
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:mindflow.sidebar",
    "onCommand:mindflow.newFlow",
    "onCommand:mindflow.openFlow",
    "onCommand:mindflow.saveFlowAs",
    "onCommand:mindflow.copyMcpConfig",
    "onCustomEditor:mindflow.productFlow",
    "onLanguage:mindflow",
    "onCommand:mindflow.validateFlowJson"
  ],
  "bin": {
    "mindflow-mcp": "./out/src/mcp/stdioBridge.js"
  },
  "main": "./out/src/vscode/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mindflow",
          "title": "MindFlow",
          "icon": "src/webview/media/icon.svg"
        }
      ]
    },
    "views": {
      "mindflow": [
        {
          "id": "mindflow.sidebar",
          "name": "MindFlow",
          "type": "webview"
        }
      ]
    },
    "languages": [
      {
        "id": "mindflow",
        "aliases": [
          "MindFlow",
          "mindflow"
        ],
        "extensions": [
          ".mindflow"
        ],
        "icon": {
          "light": "src/webview/media/icon.svg",
          "dark": "src/webview/media/icon.svg"
        }
      }
    ],
    "customEditors": [
      {
        "viewType": "mindflow.productFlow",
        "displayName": "MindFlow Product Flow",
        "selector": [
          {
            "filenamePattern": "*.mindflow"
          }
        ],
        "priority": "default"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": [
          "*.mindflow"
        ],
        "url": "./src/domain/schema/productFlow.schema.json"
      }
    ],
    "commands": [
      {
        "command": "mindflow.newFlow",
        "title": "MindFlow: New Blank Flow"
      },
      {
        "command": "mindflow.openFlow",
        "title": "MindFlow: Open Product Flow"
      },
      {
        "command": "mindflow.saveFlowAs",
        "title": "MindFlow: Save Flow As..."
      },
      {
        "command": "mindflow.validateFlowJson",
        "title": "MindFlow: Validate Flow JSON"
      },
      {
        "command": "mindflow.copyMcpConfig",
        "title": "MindFlow: Copy MCP Client Config"
      }
    ],
    "configuration": {
      "title": "MindFlow",
      "properties": {
        "mindflow.storage.flowDirectory": {
          "type": "string",
          "default": ".mindflow/flows",
          "description": "Workspace-relative directory where MindFlow ProductFlow files are stored."
        }
      }
    }
  },
  "scripts": {
    "build:webview": "node scripts/build-webview.mjs",
    "smoke:webview": "node scripts/render-webview-smoke.mjs",
    "compile": "npm run build:webview && tsc -p ./",
    "typecheck": "npm run build:webview && tsc -p ./ --noEmit",
    "watch": "npm run build:webview && tsc -watch -p ./",
    "package": "node scripts/package-vsix.mjs",
    "test": "node scripts/run-tests.mjs"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "typescript": "5.5.4"
  }
}
