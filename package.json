{
  "name": "mindflow-canvas-editor",
  "displayName": "MindFlow 产品思维画布",
  "description": "面向产品经理的结构化产品思维画布：使用节点、连线、应用形态、业务域、角色与状态描述产品，并通过 MCP 与 Agent Skills 支持可审阅的 AI 辅助分析和渐进式编辑。",
  "version": "0.1.0",
  "publisher": "mindflow",
  "repository": {
    "type": "git",
    "url": "https://github.com/WangTW98/MindFlow.git"
  },
  "homepage": "https://github.com/WangTW98/MindFlow#readme",
  "bugs": {
    "url": "https://github.com/WangTW98/MindFlow/issues"
  },
  "license": "AGPL-3.0-only",
  "engines": {
    "vscode": "^1.92.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "产品经理",
    "思维导图",
    "产品设计",
    "业务流程",
    "MCP",
    "Agent",
    "ProductFlow"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:mindflow.sidebar",
    "onCommand:mindflow.newFlow",
    "onCommand:mindflow.openFlow",
    "onCommand:mindflow.saveFlowAs",
    "onCommand:mindflow.copyGlobalMcpConfig",
    "onCommand:mindflow.exportAgentSkills",
    "onCommand:mindflow.showMcpConnectionStatus",
    "onCustomEditor:mindflow.productFlow",
    "onLanguage:mindflow",
    "onCommand:mindflow.validateFlowJson"
  ],
  "main": "./out/platform/vscode/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mindflow",
          "title": "MindFlow",
          "icon": "assets/webview/media/icon.svg"
        }
      ]
    },
    "views": {
      "mindflow": [
        {
          "id": "mindflow.sidebar",
          "name": "MindFlow",
          "type": "webview"
        }
      ]
    },
    "languages": [
      {
        "id": "mindflow",
        "aliases": [
          "MindFlow",
          "mindflow"
        ],
        "extensions": [
          ".mindflow"
        ],
        "icon": {
          "light": "assets/webview/media/icon.svg",
          "dark": "assets/webview/media/icon.svg"
        }
      }
    ],
    "customEditors": [
      {
        "viewType": "mindflow.productFlow",
        "displayName": "MindFlow 产品思维画布",
        "selector": [
          {
            "filenamePattern": "*.mindflow"
          }
        ],
        "priority": "default"
      }
    ],
    "jsonValidation": [
      {
        "fileMatch": [
          "*.mindflow"
        ],
        "url": "./assets/product-flow/schema/productFlow.schema.json"
      }
    ],
    "commands": [
      {
        "command": "mindflow.newFlow",
        "title": "MindFlow: 新建空白画布"
      },
      {
        "command": "mindflow.openFlow",
        "title": "MindFlow: 打开产品流程"
      },
      {
        "command": "mindflow.saveFlowAs",
        "title": "MindFlow: 画布另存为..."
      },
      {
        "command": "mindflow.validateFlowJson",
        "title": "MindFlow: 校验画布 JSON"
      },
      {
        "command": "mindflow.copyGlobalMcpConfig",
        "title": "MindFlow: 复制全局 MCP 配置"
      },
      {
        "command": "mindflow.exportAgentSkills",
        "title": "MindFlow: 导出 Agent Skills"
      },
      {
        "command": "mindflow.showMcpConnectionStatus",
        "title": "MindFlow: 查看 MCP 连接状态"
      }
    ],
    "configuration": {
      "title": "MindFlow",
      "properties": {
        "mindflow.storage.flowDirectory": {
          "type": "string",
          "default": ".mindflow/flows",
          "description": "用于存放 MindFlow ProductFlow 文件的工作区相对目录。"
        },
        "mindflow.security.externalFileAccess": {
          "type": "string",
          "enum": ["prompt", "allow", "workspaceOnly"],
          "enumDescriptions": [
            "访问工作区外的本地 .mindflow 文件前询问用户。",
            "允许 MCP 访问工作区外的本地 .mindflow 文件。",
            "仅允许 MCP 访问当前工作区内的本地 .mindflow 文件。"
          ],
          "default": "prompt",
          "description": "控制 MCP 是否可以打开当前 VS Code 工作区之外的本地 .mindflow 文件。"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run check:package",
    "clean": "node -e \"require('node:fs').rmSync('out',{recursive:true,force:true})\"",
    "build:webview": "node scripts/build-webview.mjs",
    "smoke:webview": "node scripts/render-webview-smoke.mjs",
    "build:mcp-router": "node scripts/build-mcp-router.mjs",
    "build:extension": "node scripts/build-extension.mjs",
    "check:build": "node scripts/check-build-budgets.mjs",
    "check:package": "node scripts/check-package-contents.mjs",
    "sync:agent-skills": "node scripts/sync-agent-skills.mjs",
    "check:agent-skills": "node scripts/sync-agent-skills.mjs --check",
    "compile": "npm run clean && npm run build:webview && npm run build:mcp-router && tsc -p ./ --noEmit && npm run build:extension && npm run check:build",
    "typecheck": "npm run build:webview && npm run build:mcp-router && tsc -p ./ --noEmit && tsc -p ./tsconfig.webview.json && tsc -p ./tsconfig.test.json --noEmit",
    "lint": "eslint src test scripts",
    "coverage": "c8 --all --check-coverage --include='out-test/src/**/*.js' --exclude='out-test/src/platform/vscode/**' --exclude='out-test/src/platform/webview/canvas/client/**' --lines=70 --functions=70 --branches=60 node scripts/run-tests.mjs",
    "test:extension": "npm run compile && tsc -p ./tsconfig.test.json && node scripts/run-extension-e2e.mjs",
    "check": "npm run check:agent-skills && npm run lint && npm test && npm run typecheck && npm run smoke:webview && npm run compile && npm run check:package && npm run coverage",
    "watch": "npm run build:webview && tsc -watch -p ./",
    "package": "vsce package --no-dependencies --readme-path README.vscode.md",
    "test": "node scripts/run-tests.mjs"
  },
  "devDependencies": {
    "@types/node": "20.16.1",
    "@types/vscode": "1.92.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "ajv": "^8.18.0",
    "c8": "^11.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "typescript": "5.5.4",
    "typescript-eslint": "^8.64.0"
  }
}
